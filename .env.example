# .env.example for UNIA
# Follows strict Easypanel guidelines: no empty/ghost values.

# Server Configuration
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
# Use the same network/host provided by Easypanel
DB_HOST=unia-db
DB_PORT=5432
DB_USER=unia_admin
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE
DB_NAME=unia_prm

# Authentication
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE

# AI Configuration (Ephemeral)
OPENAI_API_KEY=your_key_here

# Deploy Settings
ENABLE_REGISTRATION=true
ENABLE_AI_MEDIATOR=true
